{
  "name": "epm-journal",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "expo": "~53.0.0",
    "expo-av": "^15.1.7",
    "expo-constants": "~17.1.8",
    "expo-linking": "~7.1.7",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.11",
    "expo-status-bar": "~2.2.3",
    "nanoid": "^3.3.15",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-reanimated": "~3.17.5",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.14",
    "typescript": "~5.8.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios --localhost",
    "ios:device": "expo start --tunnel",
    "web": "expo start --web"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "pnpm": {
    "overrides": {
      "react-dom": "19.0.0"
    }
  }
}
